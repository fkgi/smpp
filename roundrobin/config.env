## configuration of Round-Robin debugger for SMPP

## SMPP protocol parameter
# system ID (default: hostname)
SYSTEM_ID=ROUNDROBIN

# password (default: )
PASSWORD=password

# system type (default: )
TYPE=DEBUGGER

# ESME address: ton:npi:digits
ADDRESS=0:0:123

# local address: IP (default: system auto select)
LOCAL_ADDR=

# peer SMSC address: IP[:port] (default port: 2775)
PEER_ADDR0=1.2.3.4
PEER_ADDR1=1.2.3.5
PEER_ADDR2=
PEER_ADDR3=
PEER_ADDR4=
PEER_ADDR5=
PEER_ADDR6=
PEER_ADDR7=
PEER_ADDR8=
PEER_ADDR9=

# enable TLS for SMPP connection: yes|no (default: no)
TLS=no

# encoding for default alphabet: ascii|gsm7bit (default: ascii)
DEFAULT_ALPHABET=ascii

# PDU request timeout time of second (default: 30)
TIMEOUT=30


## API parameter
# if both of the following two parameters are set, bind type will be transceiver.
# if only LOCALAPI_ADDR is set, bind type will be receiver.
# if only BACKENDAPI_ADDR is set, bind type will be transmitter.

# local API listening address
LOCALAPI_ADDR=localhost:8080

# backend API peer address
BACKENDAPI_ADDR=localhost:8080

# verbose log output: yes|no (default: no)
VERBOSE=yes
